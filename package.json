{
  "name": "clplogiserp",
  "version": "1.0.0",
  "description": "CLP 배차 관리 시스템 (데스크톱 앱)",
  "main": "electron/main.js",
  "author": "CLP",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win nsis",
    "dist-portable": "electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.clp.logiserp",
    "productName": "CLP LOGIS ERP",
    "directories": {
      "output": "dist"
    },
    "files": [
      "index.html",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CLP ERP"
    }
  }
}
